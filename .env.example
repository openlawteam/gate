# Gate — Required Environment Variables
# Copy this file to .env and fill in your values.
# Gate reads these from the shell environment (not this file directly).
# Export them in your shell profile or set them in your LaunchAgent.

# GitHub Personal Access Token (fine-grained)
# Needs: Contents (read/write), Pull Requests (read/write), Commit Statuses (read/write)
GATE_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
# Note: GH_TOKEN is automatically derived from GATE_PAT for subprocess auth.

# Claude CLI authentication token
CLAUDE_CODE_OAUTH_TOKEN=

# OpenAI API key (for Codex fix pipeline — optional if not using auto-fix)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ntfy.sh topic for push notifications (optional)
GATE_NTFY_TOPIC=

# Discord webhook URL for notifications (optional)
GATE_DISCORD_WEBHOOK=
