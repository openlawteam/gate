# Gate configuration — generated by `gate init`, customize as needed.
# See README.md for full option reference.

# Single repo:
# [repo]
# name = "org/repo"
# clone_path = "~/projects/my-repo"

# Multiple repos:
[[repos]]
name = "your-org/your-repo"
clone_path = "~/projects/your-repo"
worktree_base = "/tmp/gate-worktrees"
bot_account = "your-bot-account"
# escalation_reviewers = "user1,user2"
default_branch = "main"
project_type = "node"   # node | python | go | rust | none

# Optional: per-repo cursor rules and fix blocklist
# cursor_rules = "/path/to/config/cursor-rules.md"
# fix_blocklist = "/path/to/config/fix-blocklist.txt"

# --- Fix pipeline behavior (per-repo) ---
# Whether to run the fix pipeline for `approve_with_notes` verdicts.
# Default: true (preserves pre-1.1 behavior).
# fix_on_approve_with_notes = true
#
# When `fix_on_approve_with_notes` is true and the pipeline produces zero
# mechanical changes on the first iteration, exit as a success no-op instead
# of a failure. This stops the "red X on PR even though there's nothing
# to fix" pattern.
# Default: true.
# graceful_noop_on_approve_with_notes = true
#
# Enable the hopper-style per-finding polish loop for `approve_with_notes`.
# When false, the fixer falls back to the monolithic fix-senior call.
# This flag is the primary rollback lever if the polish loop regresses.
# Default: true.
# fix_polish_loop_enabled = true
#
# Per-finding timeouts (seconds) for the polish loop. Broad findings are
# skipped by default (timeout 0) because they are expected to require
# architectural changes that do not fit inside a bounded polish attempt.
# [repos.polish_per_finding_timeout_seconds]
# trivial = 180
# scoped = 600
# broad = 0
#
# Total wall-clock budget for the polish loop, in seconds. Any findings not
# yet attempted when the budget is exhausted are added to `not_fixed` with
# reason = "deferred_by_budget". Default: 1800 (30 minutes).
# polish_loop_total_budget_s = 1800

# --- Hopper-style fix pipeline ---
# The holistic pipeline driven by fix-senior.md + `gate checkpoint`. Replaces
# the per-finding polish loop above. Sub-scopes are decomposed by the senior,
# each one is iterated (implement → audit → checkpoint), and sub-scope
# checkpoints are squashed into a single final commit before push.
#
# Set `mode = "hopper"` per-repo to enable. During rollout we leave the
# default at `polish_legacy` so only opt-in repos get the new pipeline; flip
# per repo once you've verified on a low-stakes PR.
# [fix_pipeline]
# mode = "polish_legacy"  # "hopper" | "polish_legacy"
#
# Runaway guard: total wall-clock ceiling for a single fix run. When the
# watchdog trips it cancels the run and records `runaway_guard_hit = true`
# in reviews.jsonl. Default: 14400 (4 hours).
# max_wall_clock_s = 14400
#
# Per-senior-session timeout. Separate from the overall cap so a hung
# senior session can be detected independently of the aggregate budget.
# Default: 7200 (2 hours).
# senior_session_timeout_s = 7200
#
# Maximum implement/audit iterations per sub-scope before deferring all
# of its findings with reason = "subscope_exhausted". Default: 3.
# max_subscope_iterations = 3

# Per-repo overrides (optional):
# [repos.limits]
# max_fix_attempts_soft = 3

# [repos.timeouts]
# agent_stage_s = 900

[models]
triage = "sonnet"
postconditions = "sonnet"
architecture = "sonnet"
security = "opus"
logic = "opus"
verdict = "sonnet"
fix_senior = "opus"
fix_rereview = "sonnet"

[timeouts]
agent_stage_s = 900
structured_stage_s = 120
fix_session_s = 2400
stuck_threshold_s = 120
hard_timeout_s = 1200

[retry]
max_retries = 4
base_delay_s = 60
transient_base_delay_s = 10

[limits]
max_concurrent_reviews = 3
max_review_cycles = 5
max_fix_attempts_soft = 3
max_fix_attempts_total = 6
fix_cooldown_s = 600
max_diff_bytes = 512000
max_pr_body_bytes = 51200
max_file_list_bytes = 51200
triage_diff_budget_bytes = 153600
# Cap on how many functions the postconditions stage emits per PR.
# Higher = more coverage but longer prompt; 10 is a safe default.
postconditions_max_functions = 10

# --- Intent formalization (per-repo) ---
# Whether to run the postconditions stage on high/critical-risk PRs.
# Adds one extra structured Sonnet call (~30s). Default: true.
# Flip per-repo to disable if it produces noise for a given codebase.
# [[repos]]
# enable_postconditions = true

# --- Ambiguity halt (per-repo) ---
# When true (default), findings flagged `ambiguity: high` cause the
# fix pipeline to skip attempting a mechanical fix and post a
# disambiguation question to the PR instead of silently picking
# one of several plausible interpretations.
# halt_on_ambiguity = true
#
# Cap on how many disambiguation questions Gate posts per PR per
# review pass. Keeps the PR comment short and prevents flooding.
# max_disambig_questions_per_pr = 2
#
# After this many fix-reruns where the same pending question is still
# unanswered, Gate tells fix-senior to pick the safest interpretation
# (the one most consistent with existing tests) instead of continuing
# to halt. Default 3. Set to 0 to halt indefinitely (pipeline blocks
# until an author responds).
# max_disambig_stale_retries = 3

# --- Spec-PR promotion (per-repo, Phase 5) ---
# EXPERIMENTAL. When true (default false), after an approve verdict
# Gate will open a follow-up PR containing the logic stage's verified
# intent tests (those marked `intent_type: confirmed_correct` that
# also passed a one-point mutation check). Merging the follow-up PR
# locks the behaviour in as a living spec suite.
# persist_spec_tests = false
#
# Folder in the target repo where spec tests land. Must not match any
# path in `fix_blocklist`; otherwise promotion is skipped.
# spec_tests_dir = "tests/gate-specs"
#
# Cap on spec files promoted per source PR. Keeps the follow-up PR
# reviewable and avoids churn on PRs with large test suites.
# spec_pr_max_files = 5
#
# Base branch for the follow-up PR. Defaults to `default_branch`.
# spec_pr_base_branch = "main"

# --- Proof-based verification (per-repo, Phase 6) ---
# Command the Logic agent invokes to verify a function's formal
# contract. When non-empty, the logic prompt enables the proof-based
# verification section; a zero-exit invocation lets the agent label
# findings with `evidence_level: "proof_confirmed"` — the strongest
# tier, ranked above `test_confirmed`, and exempt from the
# mutation-check downgrade (proofs are exhaustive by construction).
#
# The field is a pass-through for the prompt. Gate's orchestrator
# does NOT run it — that is delegated to the Logic agent, scoped to
# the changed function(s).
#
# Leave empty for repos without an integrated verifier.
# [repos.build]
# verify_cmd = "dafny verify {FILE}"         # Dafny example
# verify_cmd = "verus --crate-type=lib {FILE}"   # Verus example
