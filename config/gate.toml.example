# Gate configuration — generated by `gate init`, customize as needed.
# See README.md for full option reference.

# Single repo:
# [repo]
# name = "org/repo"
# clone_path = "~/projects/my-repo"

# Multiple repos:
[[repos]]
name = "your-org/your-repo"
clone_path = "~/projects/your-repo"
worktree_base = "/tmp/gate-worktrees"
bot_account = "your-bot-account"
# escalation_reviewers = "user1,user2"
default_branch = "main"
project_type = "node"   # node | python | go | rust | none

# Optional: per-repo cursor rules and fix blocklist
# cursor_rules = "/path/to/config/cursor-rules.md"
# fix_blocklist = "/path/to/config/fix-blocklist.txt"

# --- Fix pipeline behavior (per-repo) ---
# Whether to run the fix pipeline for `approve_with_notes` verdicts.
# Default: true (preserves pre-1.1 behavior).
# fix_on_approve_with_notes = true
#
# When `fix_on_approve_with_notes` is true and the pipeline produces zero
# mechanical changes on the first iteration, exit as a success no-op instead
# of a failure. This stops the "red X on PR even though there's nothing
# to fix" pattern.
# Default: true.
# graceful_noop_on_approve_with_notes = true
#
# Enable the hopper-style per-finding polish loop for `approve_with_notes`.
# When false, the fixer falls back to the monolithic fix-senior call.
# This flag is the primary rollback lever if the polish loop regresses.
# Default: true.
# fix_polish_loop_enabled = true
#
# Per-finding timeouts (seconds) for the polish loop. Broad findings are
# skipped by default (timeout 0) because they are expected to require
# architectural changes that do not fit inside a bounded polish attempt.
# [repos.polish_per_finding_timeout_seconds]
# trivial = 180
# scoped = 600
# broad = 0
#
# Total wall-clock budget for the polish loop, in seconds. Any findings not
# yet attempted when the budget is exhausted are added to `not_fixed` with
# reason = "deferred_by_budget". Default: 1800 (30 minutes).
# polish_loop_total_budget_s = 1800

# Per-repo overrides (optional):
# [repos.limits]
# max_fix_attempts_soft = 3

# [repos.timeouts]
# agent_stage_s = 900

[models]
triage = "sonnet"
architecture = "sonnet"
security = "opus"
logic = "opus"
verdict = "sonnet"
fix_senior = "opus"
fix_rereview = "sonnet"

[timeouts]
agent_stage_s = 900
structured_stage_s = 120
fix_session_s = 2400
stuck_threshold_s = 120
hard_timeout_s = 1200

[retry]
max_retries = 4
base_delay_s = 60
transient_base_delay_s = 10

[limits]
max_concurrent_reviews = 3
max_review_cycles = 5
max_fix_attempts_soft = 3
max_fix_attempts_total = 6
fix_cooldown_s = 600
max_diff_bytes = 512000
max_pr_body_bytes = 51200
max_file_list_bytes = 51200
triage_diff_budget_bytes = 153600
